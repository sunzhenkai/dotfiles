# Codex 本地配置示例 —— 复制为 config.local.toml 后按需修改
# （config.local.toml 已被 .gitignore 忽略，不会进入版本控制）
#
# 用途：存放机器特定的配置，主要是 codex 首次信任项目时自动写入的
#       [projects."<absolute-path>"] 声明。安装脚本（dotf codex）会把
#       本文件与 codex/config.toml 合并生成 ~/.codex/config.toml。
#
# 新机快速开始：
#   cp codex/config.local.toml.example codex/config.local.toml
#   # 编辑其中的路径，然后 dotf codex

[projects."/Users/yourname/code/some-repo"]
trust_level = "trusted"
