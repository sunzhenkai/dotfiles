#!/usr/bin/env bash
# Dotfiles 统一初始化入口
# 替代 Makefile，提供安装(-i)和配置(-c)两种操作模式

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ============================================================
# 模块定义
# ============================================================

INSTALL_MODULES=(homebrew system sdk golang senv grepom mdserve git fonts npm cursor vcpkg ossutil)

CONFIG_MODULES=(starship nvim kitty k9s tmux alacritty zellij ghostty wezterm zsh yazi hypr helix shell_gpt zed fcitx5 git opencode claude)

# 安装模块描述
get_install_desc() {
  case "$1" in
  homebrew) echo "安装 Homebrew 包管理器" ;;
  system) echo "系统配置（软件源、依赖等）" ;;
  sdk) echo "安装 SDK（Go/Python/Node via mise）" ;;
  golang) echo "配置 Golang 环境（GOPATH 等）" ;;
  senv) echo "安装 senv 二进制工具" ;;
  grepom) echo "安装 grepom 多仓库管理工具" ;;
  mdserve) echo "安装 mdserve 二进制工具" ;;
  git) echo "配置 Git" ;;
  fonts) echo "安装字体（Maple Mono NF CN）" ;;
  npm) echo "安装 npm 全局包（docsify-cli 等）" ;;
  cursor) echo "安装 Cursor CLI" ;;
  vcpkg) echo "安装 vcpkg C++ 包管理器" ;;
  ossutil) echo "安装 ossutil 2.0（阿里云 OSS CLI）" ;;
  *) echo "$1" ;;
  esac
}

# 配置模块描述
get_config_desc() {
  case "$1" in
  starship) echo "Starship 提示符配置" ;;
  nvim) echo "Neovim 编辑器配置" ;;
  kitty) echo "Kitty 终端配置" ;;
  k9s) echo "Kubernetes CLI 配置" ;;
  tmux) echo "Tmux 终端复用器配置" ;;
  alacritty) echo "Alacritty 终端配置" ;;
  zellij) echo "Zellij 终端复用器配置" ;;
  ghostty) echo "Ghostty 终端配置" ;;
  wezterm) echo "WezTerm 终端配置" ;;
  zsh) echo "Zsh shell 配置" ;;
  yazi) echo "Yazi 文件管理器配置" ;;
  hypr) echo "Hyprland 窗口管理器配置" ;;
  helix) echo "Helix 编辑器配置" ;;
  shell_gpt) echo "Shell-GPT 配置" ;;
  zed) echo "Zed 编辑器配置" ;;
  fcitx5) echo "Fcitx5 输入法配置" ;;
  git) echo "Git 配置文件" ;;
  opencode) echo "OpenCode 配置" ;;
  claude) echo "Claude Code/Desktop 配置" ;;
  *) echo "$1" ;;
  esac
}

# ============================================================
# 工具函数
# ============================================================

# 检测 Homebrew bash（install-config.sh 需要 bash 4+ 的 declare -A）
get_bash() {
  if [ -x /opt/homebrew/bin/bash ]; then
    echo "/opt/homebrew/bin/bash"
  else
    echo "/bin/bash"
  fi
}

# 检查模块名是否在数组中
# 用法: in_array "name" "${array[@]}"
in_array() {
  local needle="$1"
  shift
  for item in "$@"; do
    if [ "$item" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

# ============================================================
# 交互选择
# ============================================================

# 选择模块（通用）
# 参数: $1=模块类型描述("安装"/"配置")  $2=描述函数名  shift 2 后为模块数组
# 输出: 选中的模块名写入全局 SELECTED_RESULT 数组
select_modules() {
  local type_label="$1"
  local desc_func="$2"
  shift 2
  local modules=("$@")

  SELECTED_RESULT=()

  while true; do
    echo ""
    echo "${type_label}模块:"
    local i=1
    for m in "${modules[@]}"; do
      printf "  %2d) %-12s %s\n" "$i" "$m" "$("$desc_func" "$m")"
      i=$((i + 1))
    done
    echo ""
    echo -n "请选择 (数字/名称，空格分隔，a=全部): "
    read -r input

    # 全选
    if [ "$input" = "a" ] || [ "$input" = "A" ]; then
      SELECTED_RESULT=("${modules[@]}")
      return 0
    fi

    # 解析输入
    local parsed=()
    local has_error=0
    for token in $input; do
      # 检查是否为数字
      if [[ "$token" =~ ^[0-9]+$ ]]; then
        if [ "$token" -ge 1 ] && [ "$token" -le "${#modules[@]}" ]; then
          local mod="${modules[$((token - 1))]}"
          # 去重
          if ! in_array "$mod" "${parsed[@]}"; then
            parsed+=("$mod")
          fi
        else
          echo "  ⚠ 超出范围: $token (1-${#modules[@]})"
          has_error=1
        fi
      # 检查是否为模块名
      elif in_array "$token" "${modules[@]}"; then
        if ! in_array "$token" "${parsed[@]}"; then
          parsed+=("$token")
        fi
      else
        echo "  ⚠ 无效: $token"
        has_error=1
      fi
    done

    if [ ${#parsed[@]} -eq 0 ]; then
      echo "  未选择任何模块，请重新输入。"
      continue
    fi

    SELECTED_RESULT=("${parsed[@]}")
    return 0
  done
}

# ============================================================
# 帮助信息
# ============================================================

show_help() {
  echo "Dotfiles 初始化工具"
  echo ""
  echo "用法: ./init [选项] [模块...]"
  echo ""
  echo "选项:"
  echo "  -i, --install [模块...]  安装工具/SDK"
  echo "  -c, --config  [模块...]  配置/链接配置文件"
  echo "  -a, --all                安装全部工具 + 配置全部"
  echo "  -h, --help               显示帮助"
  echo ""
  echo "安装模块 (-i):"
  for m in "${INSTALL_MODULES[@]}"; do
    printf "  %-12s %s\n" "$m" "$(get_install_desc "$m")"
  done
  echo ""
  echo "配置模块 (-c):"
  for m in "${CONFIG_MODULES[@]}"; do
    printf "  %-12s %s\n" "$m" "$(get_config_desc "$m")"
  done
  echo ""
  echo "示例:"
  echo "  ./init                    # 显示帮助"
  echo "  ./init -i sdk             # 安装 SDK"
  echo "  ./init -c nvim            # 配置 nvim"
  echo "  ./init -i sdk -c nvim     # 安装 SDK + 配置 nvim"
  echo "  ./init -a                 # 全部安装 + 配置"
}

# ============================================================
# 委托调用
# ============================================================

# 执行安装模块
run_install() {
  local modules=("$@")

  if [ ${#modules[@]} -eq 0 ]; then
    # 无指定模块 → 交互选择
    select_modules "安装" "get_install_desc" "${INSTALL_MODULES[@]}"
    modules=("${SELECTED_RESULT[@]}")
  fi

  if [ ${#modules[@]} -gt 0 ]; then
    bash "$SCRIPT_DIR/scripts/init.sh" "${modules[@]}"
  fi
}

# 执行配置模块
run_config() {
  local modules=("$@")

  if [ ${#modules[@]} -eq 0 ]; then
    # 无指定模块 → 交互选择
    select_modules "配置" "get_config_desc" "${CONFIG_MODULES[@]}"
    modules=("${SELECTED_RESULT[@]}")
  fi

  local bash_bin
  bash_bin="$(get_bash)"

  for mod in "${modules[@]}"; do
    "$bash_bin" "$SCRIPT_DIR/scripts/install-config.sh" "$mod"
  done
}

# 执行全部
run_all() {
  bash "$SCRIPT_DIR/scripts/init.sh" --all
  local bash_bin
  bash_bin="$(get_bash)"
  "$bash_bin" "$SCRIPT_DIR/scripts/install-config.sh" --all
}

# ============================================================
# 参数解析
# ============================================================

main() {
  # 无参数 → 显示帮助
  if [ $# -eq 0 ]; then
    show_help
    exit 0
  fi

  local mode=""
  local install_modules=()
  local config_modules=()

  while [ $# -gt 0 ]; do
    case "$1" in
    -i | --install)
      mode="install"
      ;;
    -c | --config)
      mode="config"
      ;;
    -a | --all)
      run_all
      exit 0
      ;;
    -h | --help)
      show_help
      exit 0
      ;;
    -*)
      echo "错误: 未知选项 '$1'"
      echo ""
      show_help
      exit 1
      ;;
    *)
      # 非 flag 参数 → 归入当前模式的模块列表
      if [ "$mode" = "install" ]; then
        install_modules+=("$1")
      elif [ "$mode" = "config" ]; then
        config_modules+=("$1")
      else
        echo "错误: 请先指定模式 (-i 或 -c)"
        echo ""
        show_help
        exit 1
      fi
      ;;
    esac
    shift
  done

  # 验证模块名
  for m in "${install_modules[@]}"; do
    if ! in_array "$m" "${INSTALL_MODULES[@]}"; then
      echo "错误: 未知安装模块 '$m'"
      echo "可用模块: ${INSTALL_MODULES[*]}"
      exit 1
    fi
  done

  for m in "${config_modules[@]}"; do
    if ! in_array "$m" "${CONFIG_MODULES[@]}"; then
      echo "错误: 未知配置模块 '$m'"
      echo "可用模块: ${CONFIG_MODULES[*]}"
      exit 1
    fi
  done

  # 执行
  if [ ${#install_modules[@]} -gt 0 ] || [ "$mode" = "install" ]; then
    run_install "${install_modules[@]}"
  fi

  if [ ${#config_modules[@]} -gt 0 ] || [ "$mode" = "config" ]; then
    run_config "${config_modules[@]}"
  fi
}

main "$@"
